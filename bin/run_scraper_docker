#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT_DIR"

if docker compose version >/dev/null 2>&1; then
  COMPOSE_CMD=(docker compose)
elif command -v docker-compose >/dev/null 2>&1; then
  COMPOSE_CMD=(docker-compose)
else
  echo "ERROR: docker compose is not available." >&2
  exit 1
fi

if command -v sudo >/dev/null 2>&1 && [ "${USE_SUDO:-1}" = "1" ] && [ "$(id -u)" -ne 0 ]; then
  SUDO_PREFIX=(sudo)
else
  SUDO_PREFIX=()
fi

if [ "${MOUNT_REPO:-1}" = "1" ]; then
  EXTRA_ARGS=(-v "${ROOT_DIR}:/app")
else
  EXTRA_ARGS=()
fi

exec "${SUDO_PREFIX[@]}" "${COMPOSE_CMD[@]}" run --rm --build "${EXTRA_ARGS[@]}" scraper bin/run_scraper "$@"
